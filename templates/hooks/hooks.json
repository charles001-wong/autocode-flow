{
  "_comment": "autocode hooks for {{project_name}} — generated by autocode-flow",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|StrReplace",
        "description": "Auto-lint after file changes",
        "command": "{{lint_cmd}} --fix {{source_glob}} 2>/dev/null || true",
        "enabled": {{lint_on_save}}
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Shell",
        "description": "Remind about test coverage before running git commit",
        "command": "echo 'Reminder: ensure test coverage meets {{coverage_target}}% before committing'",
        "condition": "command contains 'git commit'",
        "enabled": true
      }
    ],
    "Stop": [
      {
        "description": "Run tests after implementation stops",
        "command": "{{test_runner_cmd}} 2>&1 | tail -20",
        "enabled": {{test_auto_run}}
      }
    ]
  }
}
